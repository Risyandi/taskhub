        {
            "name": "Create Task",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Complete Project TaskHub\",\n    \"description\": \"This task is very urgent to finish\",\n    \"date_deadline\": \"15\\/04\\/2026\",\n    \"priority\": \"high\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/tasks",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ]
                }
            }
        },
        {
            "name": "Get Tasks (Filter & Sort)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/tasks?sort=deadline&priority=high",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ],
                    "query": [
                        {
                            "key": "sort",
                            "value": "deadline"
                        },
                        {
                            "key": "priority",
                            "value": "high"
                        }
                    ]
                }
            }
        },
