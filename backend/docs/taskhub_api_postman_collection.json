        {
            "name": "Get Tasks (All - Newest First)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/tasks?sort=newest&page=1&per_page=10",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ],
                    "query": [
                        {
                            "key": "sort",
                            "value": "newest",
                            "description": "Sort order. Accepted: newest (default), oldest, priority, deadline"
                        },
                        {
                            "key": "page",
                            "value": "1",
                            "description": "Page number to retrieve. Default: 1"
                        },
                        {
                            "key": "per_page",
                            "value": "10",
                            "description": "Number of tasks per page. Default: 10, max: 100"
                        }
                    ]
                },
                "description": "Fetch the first page of all tasks for the authenticated user sorted by newest first (default).\n\nResponse returns a paginated envelope:\n- `data`: array of task objects (each includes `need_attention` flag)\n- `meta`: pagination info (current_page, last_page, per_page, total, from, to)\n- `links`: first, last, prev, next URLs"
            }
        },
        {
            "name": "Get Tasks (Paginated - Page 2)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/tasks?sort=newest&page=2&per_page=5",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ],
                    "query": [
                        {
                            "key": "sort",
                            "value": "newest",
                            "description": "Sort order. Accepted: newest (default), oldest, priority, deadline"
                        },
                        {
                            "key": "page",
                            "value": "2",
                            "description": "Page number to retrieve. Default: 1"
                        },
                        {
                            "key": "per_page",
                            "value": "5",
                            "description": "Number of tasks per page. Default: 10, max: 100"
                        }
                    ]
                },
                "description": "Demonstrates pagination — fetches page 2 with 5 tasks per page.\n\nChange `page` to navigate between pages. Change `per_page` to control page size (max 100).\n\nThe `meta` object in the response tells you:\n- `current_page`: the current page\n- `last_page`: total number of pages\n- `total`: total number of matching tasks across all pages\n- `from` / `to`: 1-based index range of items on this page\n\nThe `links` object provides ready-made URLs for `first`, `last`, `prev`, and `next` pages."
            }
        },
