                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Complete Project TaskHub\",\n    \"description\": \"This task is very urgent to finish\",\n    \"date_deadline\": \"15\\/04\\/2026\",\n    \"priority\": \"high\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/tasks",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ]
                }
            }
        },
        {
            "name": "Get Tasks (All - Newest First)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/tasks?sort=newest",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ],
                    "query": [
                        {
                            "key": "sort",
                            "value": "newest",
                            "description": "Sort order. Accepted: newest (default), oldest, priority, deadline"
                        }
                    ]
                },
                "description": "Fetch all tasks for the authenticated user sorted by newest first (default)."
            }
        },
        {
            "name": "Get Tasks (Filter: High Priority)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/tasks?priority=high&sort=newest",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "tasks"
                    ],
                    "query": [
                        {
                            "key": "priority",
                            "value": "high",
                            "description": "Filter by priority. Accepted values: low, moderate, high"
                        },
                        {
                            "key": "sort",
                            "value": "newest",
                            "description": "Sort order. Accepted: newest (default), oldest, priority, deadline"
                        }
                    ]
                },
                "description": "Fetch only high priority tasks. Use `priority=low` or `priority=moderate` for other levels."
            }
        },
        {
            "name": "Get Tasks (Filter: Deadline Approaching)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
