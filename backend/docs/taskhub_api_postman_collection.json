                        "api",
                        "tasks"
                    ],
                    "query": [
                        {
                            "key": "deadline",
                            "value": "approaching",
                            "description": "Filter tasks with date_deadline <= tomorrow that are not yet completed"
                        },
                        {
                            "key": "sort",
                            "value": "deadline",
                            "description": "Sort by deadline ascending"
                        }
                    ]
                },
                "description": "Fetch tasks whose deadline is today or tomorrow and have not been completed yet."
            }
        },
        {
            "name": "Get Tasks (Filter: In Progress / Pending)",
